# Database
DATABASE_URL=postgres://crm_user:crm_password@localhost:5432/crm_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT - REQUIRED
JWT_SECRET=change-this-to-a-secure-random-string

# Refresh Token (falls back to JWT_SECRET if not set)
REFRESH_TOKEN_SECRET=change-this-to-a-secure-random-string

# Access Token Expiry (minutes)
ACCESS_TOKEN_EXPIRY_MINUTES=15

# Refresh Token Expiry (days)
REFRESH_TOKEN_EXPIRY_DAYS=30

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backup
BACKUP_DIR=./backups

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=change-this
SMTP_FROM=noreply@example.com

# Frontend URL (for OAuth redirect back)
FRONTEND_URL=http://localhost:3000

# OAuth / Social Login (optional — uncomment to enable)
# Create OAuth app credentials at each provider's developer console.
# The callback URL format is: {FRONTEND_URL}/api/v1/auth/oauth/{provider}/callback
# Example: http://localhost:3000/api/v1/auth/oauth/google/callback

# Google OAuth 2.0
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=

# Microsoft (Entra ID / Outlook) OAuth 2.0
# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=

# ─── Database-stored config (configured via Settings UI) ───
# WhatsApp Business API → Settings > Integraciones > WhatsApp
# AI provider (Ollama/OpenAI/Anthropic) → Settings > Integraciones > Inteligencia Artificial
# Lead assignment rules → Settings > Integraciones > Asignación de leads
# Branding → Admin > Branding
# Pipelines & stages → Admin > Embudos
# Profiles & permissions → Admin > Perfiles
# ─────────────────────────────────────────────────────────────

# Monitoring
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
